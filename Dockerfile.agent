ARG GO_VERSION=1.24
FROM golang:${GO_VERSION} AS build-opsro
WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
RUN CGO_ENABLED=0 GOOS=linux GOARCH=$(go env GOARCH) go build -o /out/opsro ./cmd/opsro

FROM node:22-bookworm-slim
ARG TARGETARCH
ARG KUBECTL_VERSION=v1.34.1
ARG AGENT_PACKAGE=@openai/codex
ARG AGENT_BIN=codex
ENV OPSRO_HOME=/opt/opsro

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git openssh-client \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p ${OPSRO_HOME}/bin
RUN ARCH="${TARGETARCH}" \
    && if [ -z "$ARCH" ]; then \
         case "$(uname -m)" in \
           x86_64) ARCH=amd64 ;; \
           aarch64|arm64) ARCH=arm64 ;; \
           *) echo "unsupported architecture: $(uname -m)" && exit 1 ;; \
         esac; \
       fi \
    && curl -fsSL -o ${OPSRO_HOME}/bin/kubectl "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${ARCH}/kubectl" \
    && chmod +x ${OPSRO_HOME}/bin/kubectl

RUN mv /usr/bin/ssh ${OPSRO_HOME}/bin/ssh
COPY docker/deny-direct.sh /usr/local/bin/kubectl
COPY docker/deny-direct.sh /usr/local/bin/ssh
RUN chmod +x /usr/local/bin/kubectl /usr/local/bin/ssh

RUN npm install -g ${AGENT_PACKAGE}
COPY --from=build-opsro /out/opsro /usr/local/bin/opsro
COPY docker/agent-entrypoint.sh /usr/local/bin/agent-entrypoint
RUN chmod +x /usr/local/bin/agent-entrypoint

ENV OPSRO_KUBECTL=${OPSRO_HOME}/bin/kubectl
ENV OPSRO_SSH=${OPSRO_HOME}/bin/ssh
ENV OPSRO_AGENT_BIN=${AGENT_BIN}
WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/agent-entrypoint"]
CMD ["/bin/sh"]
